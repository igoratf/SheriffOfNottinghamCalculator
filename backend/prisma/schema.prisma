generator client {
    provider = "prisma-client-js"
    // I recommend removing 'output' for now to use the default location
    // unless you have a specific reason to keep it custom.
}

datasource db {
    provider = "postgresql"
}

model Match {
    id        Int           @id @default(autoincrement())
    createdAt DateTime      @default(now())
    players   MatchPlayer[]
}

model MatchPlayer {
    id      Int   @id @default(autoincrement())
    matchId Int
    match   Match @relation(fields: [matchId], references: [id])

    playerName String

    // Basic Goods
    appleCount   Int @default(0)
    breadCount   Int @default(0)
    cheeseCount  Int @default(0)
    chickenCount Int @default(0)

    // Currency and calculated bonuses
    coins          Int @default(0)
    kingQueenBonus Int @default(0)
    totalScore     Int @default(0)

    // Relationship to which contrabands they had
    contrabands PlayerContraband[]
}

model Contraband {
    id            Int     @id @default(autoincrement())
    name          String
    score         Int
    resourceBonus Int     @default(0)
    resourceType  String? // "apple", "bread", "cheese" or "chicken"

    // Back-reference to the bridge table
    playersWithThis PlayerContraband[]
}

// THE BRIDGE TABLE: Specifically links a player to their contraband cards
model PlayerContraband {
    id Int @id @default(autoincrement())

    // Relation to the player
    matchPlayer   MatchPlayer @relation(fields: [matchPlayerId], references: [id])
    matchPlayerId Int

    // Relation to the contraband definition
    contraband   Contraband @relation(fields: [contrabandId], references: [id])
    contrabandId Int

    // How many of this specific card they had (e.g., 2 "Silk" cards)
    quantity Int @default(1)
}
