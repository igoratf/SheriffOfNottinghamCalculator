generator client {
    provider = "prisma-client-js"
    // I recommend removing 'output' for now to use the default location
    // unless you have a specific reason to keep it custom.
}

datasource db {
    provider = "postgresql"
}

model Match {
    id        Int           @id @default(autoincrement())
    createdAt DateTime      @default(now())
    players   MatchPlayer[]
}

model MatchPlayer {
    id        Int      @id @default(autoincrement())
    createdAt DateTime @default(now())
    name      String   @default("Player")
    match     Match    @relation(fields: [matchId], references: [id])
    matchId   Int

    appleCount   Int @default(0)
    breadCount   Int @default(0)
    cheeseCount  Int @default(0)
    chickenCount Int @default(0)

    contrabands PlayerContraband[]
    coins       Int

    totalScore Int @default(0)
}

model Contraband {
    id            Int     @id @default(autoincrement())
    name          String
    score         Int
    resourceBonus Int     @default(0)
    resourceType  String? // "apple", "bread", "cheese" or "chicken"

    playersWithThis PlayerContraband[]
}

// Since a player can have multiple contrabands and contrabands can be held by multiple players
// I created this table to join them
model PlayerContraband {
    id Int @id @default(autoincrement())

    matchPlayer   MatchPlayer @relation(fields: [matchPlayerId], references: [id])
    matchPlayerId Int

    contraband   Contraband @relation(fields: [contrabandId], references: [id])
    contrabandId Int

    quantity Int @default(1)
}
