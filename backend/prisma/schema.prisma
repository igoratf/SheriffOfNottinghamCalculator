generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Resource {
    apple
    bread
    cheese
    chicken
}

model Match {
    id         Int           @id @default(autoincrement())
    createdAt  DateTime      @default(now())
    totalScore Int           @default(0)
    players    MatchPlayer[]
}

model MatchPlayer {
    id      Int    @id @default(autoincrement())
    name    String
    match   Match  @relation(fields: [matchId], references: [id])
    matchId Int

    appleCount   Int @default(0)
    breadCount   Int @default(0)
    cheeseCount  Int @default(0)
    chickenCount Int @default(0)

    contrabands PlayerContraband[]
    coins       Int                @default(0)
    king        Resource[]         @default([])
    queen       Resource[]         @default([])

    score Int @default(0)

    @@unique([matchId, name])
    @@index([matchId])
}

model Contraband {
    id            Int       @id @default(autoincrement())
    name          String    @unique
    score         Int
    resourceBonus Int       @default(0)
    resourceType  Resource?

    playersWithThis PlayerContraband[]
}

// Since a player can have multiple contrabands and contrabands can be held by multiple players
// I created this table to join them
model PlayerContraband {
    id Int @id @default(autoincrement())

    matchPlayer   MatchPlayer @relation(fields: [matchPlayerId], references: [id])
    matchPlayerId Int

    contraband   Contraband @relation(fields: [contrabandId], references: [id])
    contrabandId Int

    quantity Int @default(1)

    @@unique([matchPlayerId, contrabandId])
}
